# Gerty configuration
# Copy to .env and adjust

# Ollama (local LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Multi-model strategy (optional, for AMD Ryzen 9 / 27GB RAM)
# Chat: llama3.1:8b = good balance, fewer hallucinations. Voice: llama3.2 = fast, low-latency.
# OLLAMA_CHAT_MODEL=llama3.1:8b
# OLLAMA_VOICE_MODEL=llama3.2
# OLLAMA_TOOL_MODEL=glm4:9b
# OLLAMA_REASONING_MODEL=deepseek-r1:7b

# Temperature: 0.1 for factual/control assistant (reduces hallucinations). Higher for creative.
# OLLAMA_TEMPERATURE=0.1

# OpenRouter (cloud LLM for complex tasks)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# Telegram (mobile control)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_IDS=

# Optional: Porcupine wake word "computer" (free key at console.picovoice.ai)
# Voice works without this: use push-to-talk (mic button) or pip install openwakeword for "hey jarvis"
PICOVOICE_ACCESS_KEY=

# Speech-to-text: faster_whisper (default), vosk, groq, or auto (Groq when WiFi, else local)
STT_BACKEND=faster_whisper
# tiny=fastest for voice on CPU; base=balanced; small/medium/large-v3=better accuracy
FASTER_WHISPER_MODEL=base
FASTER_WHISPER_DEVICE=cpu
# GROQ_API_KEY=  # Optional: Groq Whisper (216x real-time). Set STT_BACKEND=groq or auto to use.

# VAD: min silence before auto-stop (ms). 700=fastest, 1200=balanced, 2000=noisy environments
VAD_MIN_SILENCE_MS=700


# RAG knowledge base (optional; defaults: nomic-embed-text, command-r7b)
# RAG_EMBED_MODEL=nomic-embed-text
# RAG_CHAT_MODEL=command-r7b

# TTS backend: piper (default) or kokoro (Kokoro-82M, ElevenLabs-like quality)
# TTS_BACKEND=kokoro

# Model paths (relative to project root)
VOSK_MODEL_PATH=models/vosk/vosk-model-small-en-us-0.15
PIPER_VOICE_PATH=models/piper/en_US-amy-medium

# Optional: server and timeouts
# SERVER_HOST=127.0.0.1
# ALARM_POLL_INTERVAL=5
# HTTP_TIMEOUT_OLLAMA=5
# HTTP_TIMEOUT_OPENROUTER=15
# OLLAMA_CHAT_TIMEOUT=180
# OLLAMA_HEALTH_TIMEOUT=2
# RAG_TOP_K=5
# RAG_SUMMARIZE_THRESHOLD=15
# RAG_RELEVANCE_THRESHOLD=0.9
