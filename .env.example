# Gerty configuration
# Copy to .env and adjust

# Ollama (local LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Multi-model strategy (optional, for AMD Ryzen 9 / 27GB RAM)
# Chat: llama3.1:8b = good balance, fewer hallucinations. Voice: llama3.2 = fast, low-latency.
# OLLAMA_CHAT_MODEL=llama3.1:8b
# OLLAMA_VOICE_MODEL=llama3.2
# OLLAMA_TOOL_MODEL=glm4:9b
# OLLAMA_REASONING_MODEL=deepseek-r1:7b
# OLLAMA_VISION_MODEL=moondream  # Screen vision: moondream (fast), qwen2.5vl:7b (quality), llava. Run: ollama pull moondream

# Temperature: 0.1 for factual/control assistant (reduces hallucinations). Higher for creative.
# OLLAMA_TEMPERATURE=0.1

# OpenRouter (cloud LLM for complex tasks; voice uses it when OpenRouter selected in chat header)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
# Deep research: model with web search (default: Grok 4.1 Fast :online). Tables saved to data/
# OPENROUTER_RESEARCH_MODEL=x-ai/grok-4.1-fast:online
# RESEARCH_OUTPUT_DIR=data
# Web plugin: max results (default 10), search_context_size (low/medium/high)
# OPENROUTER_WEB_MAX_RESULTS=10
# OPENROUTER_SEARCH_CONTEXT=high
# Quick search: fewer results for simple lookups (contact, showtimes). Default 5.
# OPENROUTER_QUICK_SEARCH_MAX_RESULTS=5
# LLM intent fallback: when chat, check if query needs web search (adds ~100-500ms). Default 1.
# GERTY_WEB_INTENT_FALLBACK=1

# Interactive browsing (BrowserUse): opt-in; can access sensitive sites. Requires Python 3.11+
# GERTY_BROWSE_ENABLED=1
# BROWSE_HEADED=1  # Show browser window for debugging
# BROWSE_STORAGE_STATE_DIR=data/auth
# BROWSE_AUTH_SITES=github.com:github.json,gmail.com:gmail.json

# Telegram (mobile control)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_IDS=

# Wake word: Picovoice "our Gurt" (recommended) or openWakeWord
# PICOVOICE_ACCESS_KEY=  # Free at console.picovoice.ai
# PICOVOICE_KEYWORD_PATH=models/wakeword/our-gurt_en_linux_v4_0_0.ppn
# WAKE_WORD_MODEL_PATH=models/wakeword/gerty.onnx  # openWakeWord fallback
# Audio pings: 1=enabled (tone when listening starts, tone when processing starts)
# PING_LISTENING_ENABLED=1
# PING_PROCESSING_ENABLED=1

# Speech-to-text: faster_whisper (default), moonshine, vosk, groq, or auto (Groq when WiFi, else local)
STT_BACKEND=faster_whisper
# Moonshine: variable-length, ~5x faster than Whisper on short commands. tiny (27M) or base (61M). Requires: pip install "transformers[torch]"
# STT_BACKEND=moonshine
# MOONSHINE_MODEL=base
# faster-whisper: tiny=fastest for voice on CPU; base=balanced; small/medium/large-v3=better accuracy
FASTER_WHISPER_MODEL=base
FASTER_WHISPER_DEVICE=cpu
# GROQ_API_KEY=  # Optional: Groq Whisper (216x real-time). Settings → Voice → STT: groq or auto. Restart after changing.

# OpenClaw - action execution (files, browser, calendar, email)
# OpenClaw uses its own config: ~/.openclaw/.env (OPENROUTER_API_KEY, BRAVE_API_KEY/PERPLEXITY_API_KEY for web search).
# GERTY_OPENCLAW_ENABLED=1
# OPENCLAW_GATEWAY_WS_URL=ws://127.0.0.1:18789/gateway
# OPENCLAW_AGENT_ID=main
# OPENCLAW_TIMEOUT=120
# OPENCLAW_CLASSIFIER_MODEL=openai/gpt-4o-mini
# OLLAMA_CLASSIFIER_MODEL=llama3.2

# VAD: min silence before auto-stop (ms). 1000=1s breathing room; 700=snappier, 1500=more relaxed
VAD_MIN_SILENCE_MS=1000
# Grace period after wake word: mic stays open this long before we consider "user stopped" (seconds)
# VOICE_WAKE_GRACE_SEC=1.5
# Auto-listen: 0=off (say wake word each time to continue). 1=on (mic auto-opens after AI responds)
# VOICE_AUTO_LISTEN_ENABLED=0


# System tools: lock, suspend, reboot, app launch (opt-in for security)
# GERTY_SYSTEM_TOOLS=1

# RAG knowledge base (optional; defaults: nomic-embed-text, command-r7b)
# RAG_EMBED_MODEL=nomic-embed-text
# RAG_CHAT_MODEL=command-r7b

# TTS backend: piper (default) or kokoro (Kokoro-82M, ElevenLabs-like quality)
# TTS_BACKEND=kokoro

# Model paths (relative to project root)
VOSK_MODEL_PATH=models/vosk/vosk-model-small-en-us-0.15
PIPER_VOICE_PATH=models/piper/en_US-amy-medium

# Optional: server and timeouts
# SERVER_HOST=127.0.0.1
# ALARM_POLL_INTERVAL=5
# HTTP_TIMEOUT_OLLAMA=5
# HTTP_TIMEOUT_OPENROUTER=15
# OLLAMA_CHAT_TIMEOUT=180
# OLLAMA_HEALTH_TIMEOUT=2
# RAG_TOP_K=5
# RAG_SUMMARIZE_THRESHOLD=15
# RAG_RELEVANCE_THRESHOLD=0.9
